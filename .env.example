# Token bot dari @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Chat ID kamu (WAJIB — bot cuma jawab chat ini; bisa beberapa, pisah koma).
# Cara dapat: chat @userinfobot di Telegram.
TELEGRAM_CHAT_ID=123456789

# Private key hot wallet (tanpa/dengan 0x sama saja)
PRIVATE_KEY=0xyourprivatekeyhex

# Opsional: override RPC default
# RPC_4663=https://rpc.mainnet.chain.robinhood.com
# RPC_56=https://1rpc.io/bnb

# Opsional tapi disarankan: API key Alchemy (https://dashboard.alchemy.com)
# Kalau diisi, bot pakai RPC Alchemy sebagai prioritas (robinhood-mainnet + bnb-mainnet,
# stabil, tidak kena blokir DNS ISP)
# ALCHEMY_API_KEY=your-key
